/* ProfileSettingsView — Network Isolation */
"Restrict which networks and ports this browser can reach" = "Restrinja a qu\U00E9 redes y puertos puede acceder este navegador";
"Isolate from Local Network" = "Aislar de la red local";
"Prevents this browser from reaching devices on your home or office network, like printers, NAS drives, or internal servers. Internet access is not affected." = "Impide que este navegador acceda a dispositivos en su red dom\U00E9stica o de oficina, como impresoras, unidades NAS o servidores internos. El acceso a internet no se ve afectado.";
"Restrict Outgoing Ports" = "Restringir puertos de salida";
"Only allow the browser to connect on specific network ports. Useful for locking down which services the browser can reach." = "Solo permite que el navegador se conecte a trav\U00E9s de puertos de red espec\U00EDficos. \U00DAtil para limitar a qu\U00E9 servicios puede acceder el navegador.";
"Allowed ports (e.g. 80, 443, 8000-9000)" = "Puertos permitidos (p. ej., 80, 443, 8000-9000)";
"DNS (port 53) is always allowed. Separate ports with commas. Use a dash for ranges." = "DNS (puerto 53) siempre est\U00E1 permitido. Separe los puertos con comas. Use un gui\U00F3n para rangos.";

/* ProfileSettingsView — VPN & Ads */
"Network privacy and ad blocking" = "Privacidad de red y bloqueo de anuncios";
"Cloudflare WARP" = "Cloudflare WARP";
"Routes all browser traffic through Cloudflare\U2019s encrypted network, hiding your IP address from websites. Works like a VPN." = "Enruta todo el tr\U00E1fico del navegador a trav\U00E9s de la red cifrada de Cloudflare, ocultando su direcci\U00F3n IP de los sitios web. Funciona como una VPN.";
"Block Ads" = "Bloquear anuncios";
"Blocks ads and tracking scripts from loading on websites. This can make pages load faster and protects your privacy." = "Bloquea anuncios y scripts de rastreo en los sitios web. Esto puede hacer que las p\U00E1ginas carguen m\U00E1s r\U00E1pido y protege su privacidad.";

/* ProfileSettingsView — Enterprise */
"Settings for managed environments" = "Ajustes para entornos administrados";
