/* ProfileSettingsView — Network Isolation */
"Restrict which networks and ports this browser can reach" = "Legen Sie fest, welche Netzwerke und Ports dieser Browser erreichen darf";
"Isolate from Local Network" = "Vom lokalen Netzwerk isolieren";
"Prevents this browser from reaching devices on your home or office network, like printers, NAS drives, or internal servers. Internet access is not affected." = "Verhindert, dass dieser Browser Ger\U00E4te in Ihrem Heim- oder B\U00FCronetzwerk erreicht, z.\U00A0B. Drucker, NAS-Laufwerke oder interne Server. Der Internetzugang wird nicht beeintr\U00E4chtigt.";
"Restrict Outgoing Ports" = "Ausgehende Ports einschr\U00E4nken";
"Only allow the browser to connect on specific network ports. Useful for locking down which services the browser can reach." = "Dem Browser nur erlauben, \U00FCber bestimmte Netzwerkports zu verbinden. N\U00FCtzlich, um einzuschr\U00E4nken, welche Dienste der Browser erreichen kann.";
"Allowed ports (e.g. 80, 443, 8000-9000)" = "Erlaubte Ports (z.\U00A0B. 80, 443, 8000\U20139000)";
"DNS (port 53) is always allowed. Separate ports with commas. Use a dash for ranges." = "DNS (Port 53) ist immer erlaubt. Ports mit Kommas trennen. Bindestriche f\U00FCr Bereiche verwenden.";

/* ProfileSettingsView — VPN & Ads */
"Network privacy and ad blocking" = "Netzwerk-Datenschutz und Werbeblocker";
"Cloudflare WARP" = "Cloudflare WARP";
"Routes all browser traffic through Cloudflare\U2019s encrypted network, hiding your IP address from websites. Works like a VPN." = "Leitet den gesamten Datenverkehr des Browsers \U00FCber das verschl\U00FCsselte Netzwerk von Cloudflare, wodurch Ihre IP-Adresse vor Webseiten verborgen wird. Funktioniert wie ein VPN.";
"Block Ads" = "Werbung blockieren";
"Blocks ads and tracking scripts from loading on websites. This can make pages load faster and protects your privacy." = "Blockiert das Laden von Werbung und Tracking-Skripten auf Webseiten. Dadurch k\U00F6nnen Seiten schneller geladen werden, und Ihre Privatsph\U00E4re wird gesch\U00FCtzt.";

/* ProfileSettingsView — Enterprise */
"Settings for managed environments" = "Einstellungen f\U00FCr verwaltete Umgebungen";
"Root Certificates" = "Stammzertifikate";
"Install custom root CA certificates so the browser trusts your organization\U2019s internal websites and services. Accepts PEM, DER, CRT, and CER files." = "Installieren Sie eigene Stammzertifikate, damit der Browser den internen Webseiten und Diensten Ihrer Organisation vertraut. Akzeptiert PEM-, DER-, CRT- und CER-Dateien.";
"Add Certificate\U2026" = "Zertifikat hinzuf\U00FCgen\U2026";

/* ProfileSettingsView — Advanced */
"Additional options for power users" = "Zus\U00E4tzliche Optionen f\U00FCr fortgeschrittene Benutzer";
"Encrypt Browsing Data" = "Browserdaten verschl\U00FCsseln";
"Encrypts all saved browsing data on your Mac\U2019s disk using LUKS. The encryption key is stored securely in your macOS Keychain. If you lose the key, your data cannot be recovered." = "Verschl\U00FCsselt alle gespeicherten Browserdaten auf der Festplatte Ihres Mac mit LUKS. Der Schl\U00FCssel wird sicher in Ihrem macOS-Schl\U00FCsselbund gespeichert. Bei Verlust des Schl\U00FCssels k\U00F6nnen Ihre Daten nicht wiederhergestellt werden.";
"Encryption" = "Verschl\U00FCsselung";
"Turn on \U201CRetain Browsing Data\U201D in General to access disk encryption options." = "Aktivieren Sie \U201CBrowserdaten behalten\U201D unter \U201CAllgemein\U201D, um auf die Verschl\U00FCsselungsoptionen zuzugreifen.";

