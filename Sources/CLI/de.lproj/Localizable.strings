/* ProfileSettingsView — Privacy & Safety */
"Control what this browser can access and share" = "Steuern Sie, worauf dieser Browser zugreifen und was er teilen darf";
"Shared Clipboard" = "Geteilte Zwischenablage";
"Copy and paste text and images between your Mac and this browser. When turned off, the browser\U2019s clipboard is completely isolated." = "Text und Bilder zwischen Ihrem Mac und diesem Browser kopieren und einf\U00FCgen. Bei Deaktivierung ist die Zwischenablage des Browsers vollst\U00E4ndig isoliert.";
"File Upload" = "Datei-Upload";
"Allow sending files from your Mac to websites in this browser." = "Erlaubt das Senden von Dateien von Ihrem Mac an Webseiten in diesem Browser.";
"File Download" = "Datei-Download";
"Allow saving files from websites to your Mac." = "Erlaubt das Speichern von Dateien aus Webseiten auf Ihrem Mac.";
"Scan Downloads with VirusTotal" = "Downloads mit VirusTotal scannen";
"Automatically check downloaded files for viruses and malware before they reach your Mac." = "Heruntergeladene Dateien automatisch auf Viren und Schadsoftware pr\U00FCfen, bevor sie Ihren Mac erreichen.";
"VirusTotal API Key" = "VirusTotal-API-Schl\U00FCssel";
"Block Threats" = "Bedrohungen blockieren";
"Automatically block files that VirusTotal identifies as malicious. Blocked files cannot be saved or dragged to your Mac." = "Dateien automatisch blockieren, die VirusTotal als sch\U00E4dlich einstuft. Blockierte Dateien k\U00F6nnen nicht auf Ihrem Mac gespeichert oder dorthin gezogen werden.";
"Block Unscannable Files" = "Nicht scannbare Dateien blockieren";
"Block files that could not be scanned by VirusTotal (too large, rate-limited, or unknown). When turned off, unscannable files can still be saved manually." = "Dateien blockieren, die von VirusTotal nicht gescannt werden konnten (zu gro\U00DF, Limit erreicht oder unbekannt). Bei Deaktivierung k\U00F6nnen nicht scannbare Dateien weiterhin manuell gespeichert werden.";
"Block Malware Sites" = "Schadsoftware-Seiten blockieren";
"Blocks access to websites known to distribute viruses or steal information, using Cloudflare\U2019s security DNS." = "Blockiert den Zugriff auf Webseiten, die daf\U00FCr bekannt sind, Viren zu verbreiten oder Daten zu stehlen, mithilfe von Cloudflare\U2019s Sicherheits-DNS.";
"Phishing Warning" = "Phishing-Warnung";
"Shows a warning when you\U2019re about to enter a password on a website that looks suspicious or fake." = "Zeigt eine Warnung an, wenn Sie im Begriff sind, ein Passwort auf einer verd\U00E4chtigen oder gef\U00E4lschten Webseite einzugeben.";
"Beta" = "Beta";
"Send Link to Other Session" = "Link an andere Sitzung senden";
